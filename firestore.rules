rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only verified @hy.co Google accounts may access anything
    function isHyCo() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@hy\\.co$');
    }

    match /sessions/{sessionId} {
      // Read / update / delete: must own the session (userId field matches caller)
      allow read, update, delete: if isHyCo()
        && resource.data.userId == request.auth.uid;

      // Create: caller must set userId to their own uid
      allow create: if isHyCo()
        && request.resource.data.userId == request.auth.uid;

      match /companies/{companyId} {
        allow read, write: if isHyCo()
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
      }

      match /clusters/{clusterId} {
        allow read, write: if isHyCo()
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
      }

      match /chatHistory/{messageId} {
        allow read, write: if isHyCo()
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
