rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Any verified @hy.co user can read/write session files.
    // Session IDs are crypto.randomUUID() — unguessable without sharing.
    match /sessions/{sessionId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@hy\\.co$');
    }
  }
}
